# 环境变量配置
# 警告：请勿将包含真实敏感信息的 .env 文件提交到 Git！
# 复制此文件为 .env.local 并填入实际值

# 服务器配置
PORT=3000
NODE_ENV=development

# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=YOUR_DB_PASSWORD_HERE
DB_NAME=bbq_shop

# JWT 配置
# 生成强密钥：node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=YOUR_JWT_SECRET_HERE
JWT_EXPIRES_IN=7d

# 微信小程序配置
WX_APPID=your_wx_appid
WX_SECRET=your_wx_secret
WX_GRANT_TYPE=authorization_code

# 微信支付配置
WX_MCHID=your_merchant_id
WX_APIKEY=your_api_key
WX_NOTIFY_URL=https://yourdomain.com/api/pay/notify

# 文件上传配置
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=5242880

# CORS 配置
# 生产环境请设置为具体域名，多个域名用逗号分隔，如：https://example.com,https://admin.example.com
CORS_ORIGIN=http://localhost:3001,http://localhost:5173
