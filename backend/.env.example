# 环境变量配置
# 复制此文件为 .env 并填入实际值

# 服务器配置
PORT=3000
NODE_ENV=development

# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_database_password
DB_NAME=bbq_shop

# JWT 配置
JWT_SECRET=your_jwt_secret_key_change_this
JWT_EXPIRES_IN=7d

# 微信小程序配置
WX_APPID=your_wx_appid
WX_SECRET=your_wx_secret
WX_GRANT_TYPE=authorization_code

# 微信支付配置
WX_MCHID=your_merchant_id
WX_APIKEY=your_api_key
WX_NOTIFY_URL=https://yourdomain.com/api/pay/notify

# 文件上传配置
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=5242880

# CORS 配置
CORS_ORIGIN=*
