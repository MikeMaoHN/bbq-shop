/* 订单页样式 */
.order-confirm {
  padding-bottom: 120rpx;
}

.address-section {
  margin: 20rpx;
  padding: 30rpx;
}

.address-row {
  display: flex;
  justify-content: space-between;
  margin-bottom: 15rpx;
}

.address-row .name {
  font-size: 32rpx;
  font-weight: bold;
}

.address-row .phone {
  font-size: 28rpx;
  color: #666;
}

.address-detail {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
}

.no-address {
  display: flex;
  justify-content: space-between;
  align-items: center;
  color: #999;
}

.goods-section, .remark-section, .amount-section {
  margin: 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
}

.goods-item {
  display: flex;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.goods-item:last-child {
  border-bottom: none;
}

.goods-image {
  width: 140rpx;
  height: 140rpx;
  border-radius: 8rpx;
  margin-right: 20rpx;
}

.goods-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.goods-name {
  font-size: 28rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.goods-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.goods-price {
  font-size: 30rpx;
  font-weight: bold;
  color: #e74c3c;
}

.goods-quantity {
  font-size: 26rpx;
  color: #999;
}

.remark-input {
  width: 100%;
  min-height: 150rpx;
  font-size: 28rpx;
  line-height: 1.6;
}

.amount-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 15rpx 0;
  font-size: 28rpx;
  color: #666;
}

.amount-row.total {
  font-size: 30rpx;
  color: #333;
}

.total-amount {
  font-size: 36rpx;
  font-weight: bold;
  color: #e74c3c;
}

/* 订单列表 */
.order-tabs {
  display: flex;
  background: #fff;
  border-bottom: 1rpx solid #eee;
}

.order-tab {
  flex: 1;
  text-align: center;
  padding: 25rpx 0;
  font-size: 26rpx;
  color: #666;
  position: relative;
}

.order-tab.active {
  color: #e74c3c;
  font-weight: 500;
}

.order-tab.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 4rpx;
  background: #e74c3c;
  border-radius: 2rpx;
}

.order-list {
  padding: 20rpx;
}

.order-item {
  margin-bottom: 20rpx;
}

.order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.order-no {
  font-size: 24rpx;
  color: #999;
}

.order-status {
  font-size: 28rpx;
  color: #e74c3c;
  font-weight: 500;
}

.order-goods {
  padding: 20rpx;
}

.order-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
  border-top: 1rpx solid #f5f5f5;
}

.order-total {
  font-size: 28rpx;
  color: #666;
}

.order-actions {
  display: flex;
  gap: 20rpx;
}

.action-btn {
  padding: 12rpx 30rpx;
  font-size: 26rpx;
  border-radius: 30rpx;
  background: #f5f5f5;
  color: #666;
}

.action-btn.primary {
  background: linear-gradient(135deg, #e74c3c, #c0392b);
  color: #fff;
}

.action-btn.cancel {
  border: 1rpx solid #ddd;
}

/* 提交栏 */
.submit-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 30rpx;
  background: #fff;
  border-top: 1rpx solid #eee;
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.submit-btn {
  background: linear-gradient(135deg, #e74c3c, #c0392b);
  color: #fff;
  padding: 20rpx 60rpx;
  border-radius: 50rpx;
  font-size: 30rpx;
  font-weight: 500;
}
