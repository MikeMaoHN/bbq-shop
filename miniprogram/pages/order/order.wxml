<view class="container">
  <!-- 订单确认页 -->
  <view wx:if="{{isConfirmMode}}" class="order-confirm">
    <!-- 收货地址 -->
    <view class="address-section card" bindtap="selectAddress">
      <view class="address-content" wx:if="{{selectedAddress}}">
        <view class="address-row">
          <text class="name">{{selectedAddress.name}}</text>
          <text class="phone">{{selectedAddress.phone}}</text>
        </view>
        <view class="address-detail">{{selectedAddress.province}}{{selectedAddress.city}}{{selectedAddress.district}}{{selectedAddress.detail}}</view>
      </view>
      <view class="no-address" wx:else>
        <text>请选择收货地址</text>
        <text class="iconfont icon-arrow"></text>
      </view>
    </view>

    <!-- 商品列表 -->
    <view class="goods-section card">
      <view class="section-title">商品信息</view>
      <view class="goods-item" wx:for="{{orderItems}}" wx:key="productId">
        <image class="goods-image" src="{{item.image || '/images/default-product.png'}}" mode="aspectFill"></image>
        <view class="goods-info">
          <view class="goods-name">{{item.name}}</view>
          <view class="goods-bottom">
            <text class="goods-price">¥{{item.price / 100}}</text>
            <text class="goods-quantity">x{{item.quantity}}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 备注 -->
    <view class="remark-section card">
      <textarea 
        class="remark-input" 
        placeholder="选填：对本订单的说明（如配送时间等）" 
        bindinput="onRemarkInput"
        value="{{remark}}"
      ></textarea>
    </view>

    <!-- 金额明细 -->
    <view class="amount-section card">
      <view class="amount-row">
        <text>商品总额</text>
        <text>¥{{goodsAmount.toFixed(2)}}</text>
      </view>
      <view class="amount-row">
        <text>运费</text>
        <text wx:if="{{freightAmount > 0}}">¥{{(freightAmount / 100).toFixed(2)}}</text>
        <text wx:else>免运费</text>
      </view>
      <view class="divider"></view>
      <view class="amount-row total">
        <text>实付款</text>
        <text class="total-amount">¥{{totalAmount.toFixed(2)}}</text>
      </view>
    </view>
  </view>

  <!-- 订单列表页 -->
  <view wx:else class="order-list-page">
    <!-- 订单状态筛选 -->
    <view class="order-tabs">
      <view 
        class="order-tab {{statusFilter === '' ? 'active' : ''}}"
        bindtap="selectStatus"
        data-status=""
      >
        全部
      </view>
      <view 
        class="order-tab {{statusFilter === '0' ? 'active' : ''}}"
        bindtap="selectStatus"
        data-status="0"
      >
        待付款
      </view>
      <view 
        class="order-tab {{statusFilter === '1' ? 'active' : ''}}"
        bindtap="selectStatus"
        data-status="1"
      >
        待发货
      </view>
      <view 
        class="order-tab {{statusFilter === '2' ? 'active' : ''}}"
        bindtap="selectStatus"
        data-status="2"
      >
        待收货
      </view>
      <view 
        class="order-tab {{statusFilter === '3' ? 'active' : ''}}"
        bindtap="selectStatus"
        data-status="3"
      >
        已完成
      </view>
    </view>

    <!-- 订单列表 -->
    <view class="order-list">
      <view class="order-item card" wx:for="{{orders}}" wx:key="id">
        <view class="order-header">
          <text class="order-no">订单号：{{item.order_no}}</text>
          <text class="order-status">{{statusMap[item.status]}}</text>
        </view>
        <view class="order-goods">
          <view class="goods-item" wx:for="{{item.items}}" wx:key="id" wx:for-item="goods">
            <image class="goods-image" src="{{goods.product_image || '/images/default-product.png'}}" mode="aspectFill"></image>
            <view class="goods-info">
              <view class="goods-name">{{goods.product_name}}</view>
              <view class="goods-bottom">
                <text class="goods-price">¥{{goods.price / 100}}</text>
                <text class="goods-quantity">x{{goods.quantity}}</text>
              </view>
            </view>
          </view>
        </view>
        <view class="order-footer">
          <view class="order-total">
            <text>合计：</text>
            <text class="total-amount">¥{{item.total_amount / 100}}</text>
          </view>
          <view class="order-actions">
            <button class="action-btn cancel" wx:if="{{item.status === 0}}" bindtap="cancelOrder" data-id="{{item.id}}">取消订单</button>
            <button class="action-btn primary" wx:if="{{item.status === 0}}" bindtap="payOrder" data-id="{{item.id}}">立即付款</button>
            <button class="action-btn" wx:if="{{item.status === 2}}" bindtap="confirmReceipt" data-id="{{item.id}}">确认收货</button>
          </view>
        </view>
      </view>
    </view>

    <view class="empty" wx:if="{{orders.length === 0 && !loading}}">
      <text class="empty-text">暂无订单</text>
    </view>
  </view>

  <!-- 提交订单按钮（确认页） -->
  <view class="submit-bar" wx:if="{{isConfirmMode}}">
    <view class="total-info">
      <text>实付款：</text>
      <text class="total-amount">¥{{totalAmount.toFixed(2)}}</text>
    </view>
    <button class="submit-btn" bindtap="submitOrder">提交订单</button>
  </view>
</view>
