/* 商品/购物车页样式 */
.cart-page {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 120rpx;
}

.cart-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  background: #fff;
  border-bottom: 1rpx solid #eee;
}

.cart-header .title {
  font-size: 36rpx;
  font-weight: bold;
}

.cart-header .clear-btn {
  font-size: 26rpx;
  color: #999;
}

.cart-list {
  padding: 20rpx;
}

.cart-item {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.checkbox {
  width: 40rpx;
  height: 40rpx;
  border: 2rpx solid #ddd;
  border-radius: 50%;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.checkbox.checked {
  background: #e74c3c;
  border-color: #e74c3c;
}

.product-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 8rpx;
  margin-right: 20rpx;
}

.product-info {
  flex: 1;
}

.product-name {
  font-size: 28rpx;
  margin-bottom: 10rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.product-price {
  font-size: 32rpx;
  font-weight: bold;
  color: #e74c3c;
}

.stepper {
  display: flex;
  align-items: center;
  border: 1rpx solid #eee;
  border-radius: 8rpx;
}

.stepper-btn {
  width: 50rpx;
  height: 50rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #666;
}

.stepper-value {
  width: 60rpx;
  text-align: center;
  font-size: 28rpx;
}

.delete-btn {
  font-size: 24rpx;
  color: #999;
  padding: 10rpx;
  margin-left: 20rpx;
}

.cart-footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  padding: 20rpx 30rpx;
  background: #fff;
  border-top: 1rpx solid #eee;
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.select-all {
  display: flex;
  align-items: center;
  font-size: 28rpx;
  color: #666;
  margin-right: 30rpx;
}

.select-all::before {
  content: '';
  width: 36rpx;
  height: 36rpx;
  border: 2rpx solid #ddd;
  border-radius: 50%;
  margin-right: 10rpx;
}

.select-all.checked::before {
  background: #e74c3c;
  border-color: #e74c3c;
}

.total-info {
  flex: 1;
  font-size: 28rpx;
  color: #666;
}

.total-price {
  font-size: 36rpx;
  font-weight: bold;
  color: #e74c3c;
}

.checkout-btn {
  background: linear-gradient(135deg, #e74c3c, #c0392b);
  color: #fff;
  padding: 20rpx 50rpx;
  border-radius: 50rpx;
  font-size: 30rpx;
  font-weight: 500;
}

/* 商品详情 */
.product-detail {
  padding-bottom: 120rpx;
}

.product-swiper {
  height: 700rpx;
}

.product-swiper .product-image {
  width: 100%;
  height: 100%;
}

.product-basic {
  margin: 20rpx;
  padding: 30rpx;
}

.product-price-row {
  display: flex;
  align-items: baseline;
  margin-bottom: 20rpx;
}

.product-basic .price {
  font-size: 48rpx;
  font-weight: bold;
  color: #e74c3c;
}

.product-basic .original-price {
  font-size: 28rpx;
  color: #999;
  text-decoration: line-through;
  margin-left: 20rpx;
}

.product-basic .product-name {
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 15rpx;
}

.product-basic .product-sales {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 15rpx;
}

.stock-tag {
  display: inline-block;
  background: #fff3e0;
  color: #e74c3c;
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 4rpx;
}

.product-desc {
  margin: 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
}

.desc-content {
  font-size: 28rpx;
  color: #666;
  line-height: 1.8;
}

.product-footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  padding: 20rpx 30rpx;
  background: #fff;
  border-top: 1rpx solid #eee;
}

.footer-actions {
  display: flex;
  margin-right: 30rpx;
}

.action-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-right: 30rpx;
}

.action-btn text {
  font-size: 22rpx;
  color: #666;
  margin-top: 6rpx;
}

.buy-btn {
  flex: 1;
  background: linear-gradient(135deg, #e74c3c, #c0392b);
  color: #fff;
  border-radius: 50rpx;
  font-size: 30rpx;
  font-weight: 500;
}
